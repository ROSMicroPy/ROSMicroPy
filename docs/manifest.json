{
  "name": "ROSMicroPy Core",
  "version": "dev",
  "new_install_prompt_erase": true,
  "new_install_improv_wait_time": 0,
  "builds": [
    {
      "chipFamily": "ESP32",
      "parts": [
        { "path": "firmware/rmp_core_generic_bootloader.bin", "offset": 4096 },
        { "path": "firmware/rmp_core_generic_partition-table.bin", "offset": 32768 },
        { "path": "firmware/rmp_core_generic.bin", "offset": 65536 }
      ]
    },
    {
      "chipFamily": "ESP32-S3",
      "parts": [
        { "path": "firmware/rmp_core_s3_bootloader.bin", "offset": 0 },
        { "path": "firmware/rmp_core_s3_partition-table.bin", "offset": 32768 },
        { "path": "firmware/rmp_core_s3.bin", "offset": 65536 }
      ]
    }
  ]
}
